{
  "name": "@semajsx/mermaid",
  "version": "0.1.0",
  "private": true,
  "description": "Mermaid diagram rendering for SemaJSX — composable, themeable SVG components",
  "keywords": [
    "diagrams",
    "flowchart",
    "mermaid",
    "sequence",
    "visualization"
  ],
  "license": "MIT",
  "author": "lidessen",
  "type": "module",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "exports": {
    ".": "./src/index.ts",
    "./remark": "./src/remark-mermaid.ts",
    "./package.json": "./package.json"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config vitest.config.ts",
    "test:unit": "vitest run --config vitest.config.ts"
  },
  "dependencies": {
    "@semajsx/core": "workspace:*",
    "@semajsx/signal": "workspace:*",
    "@semajsx/style": "workspace:*"
  },
  "devDependencies": {
    "@semajsx/configs": "workspace:*",
    "@semajsx/dom": "workspace:*",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  },
  "peerDependencies": {
    "@semajsx/dom": "workspace:*"
  },
  "peerDependenciesMeta": {
    "@semajsx/dom": {
      "optional": true
    }
  }
}
