{
  "name": "@semajsx/blocks",
  "version": "0.1.0",
  "private": true,
  "description": "Block rendering system for SemaJSX with pluggable registry",
  "keywords": [
    "blocks",
    "components",
    "registry",
    "rendering"
  ],
  "license": "MIT",
  "author": "lidessen",
  "files": [
    "dist"
  ],
  "type": "module",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "default": "./dist/index.mjs"
    },
    "./renderers": {
      "source": "./src/renderers/index.ts",
      "default": "./dist/renderers/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "exports": {
      ".": "./dist/index.mjs",
      "./renderers": "./dist/renderers/index.mjs",
      "./package.json": "./package.json"
    }
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@semajsx/core": "workspace:*",
    "@semajsx/dom": "workspace:*",
    "@semajsx/signal": "workspace:*",
    "@semajsx/style": "workspace:*"
  },
  "devDependencies": {
    "@semajsx/configs": "workspace:*",
    "tsdown": "^0.20.1",
    "typescript": "^5.9.3"
  }
}
