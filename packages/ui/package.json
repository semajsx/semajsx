{
  "name": "@semajsx/ui",
  "version": "0.1.0",
  "private": true,
  "description": "Accessible UI component library for SemaJSX with theme system",
  "keywords": [
    "components",
    "design-system",
    "theme",
    "ui"
  ],
  "license": "MIT",
  "author": "lidessen",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./components/avatar": "./src/components/avatar/index.ts",
    "./components/badge": "./src/components/badge/index.ts",
    "./components/button": "./src/components/button/index.ts",
    "./components/callout": "./src/components/callout/index.ts",
    "./components/card": "./src/components/card/index.ts",
    "./components/code-block": "./src/components/code-block/index.ts",
    "./components/input": "./src/components/input/index.ts",
    "./components/kbd": "./src/components/kbd/index.ts",
    "./components/separator": "./src/components/separator/index.ts",
    "./components/steps": "./src/components/steps/index.ts",
    "./components/switch": "./src/components/switch/index.ts",
    "./components/tabs": "./src/components/tabs/index.ts",
    "./theme": "./src/theme/index.ts",
    "./package.json": "./package.json"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest --config vitest.config.ts",
    "test:run": "vitest run --config vitest.config.ts"
  },
  "dependencies": {
    "@semajsx/core": "workspace:*",
    "@semajsx/signal": "workspace:*",
    "@semajsx/style": "workspace:*"
  },
  "devDependencies": {
    "@semajsx/configs": "workspace:*",
    "@semajsx/dom": "workspace:*",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  },
  "peerDependencies": {
    "@semajsx/dom": "workspace:*"
  },
  "peerDependenciesMeta": {
    "@semajsx/dom": {
      "optional": true
    }
  }
}
