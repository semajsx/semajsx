{
  "name": "@semajsx/ui",
  "version": "0.1.0",
  "private": true,
  "description": "Accessible UI component library for SemaJSX with theme system",
  "keywords": [
    "components",
    "design-system",
    "theme",
    "ui"
  ],
  "license": "MIT",
  "author": "lidessen",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": "./src/index.ts",
    "./theme": "./src/theme/index.ts",
    "./button": "./src/components/button/index.ts",
    "./card": "./src/components/card/index.ts",
    "./callout": "./src/components/callout/index.ts",
    "./badge": "./src/components/badge/index.ts",
    "./code-block": "./src/components/code-block/index.ts",
    "./css": "./src/css.ts",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "exports": {
      ".": "./dist/index.mjs",
      "./theme": "./dist/theme/index.mjs",
      "./button": "./dist/components/button/index.mjs",
      "./card": "./dist/components/card/index.mjs",
      "./callout": "./dist/components/callout/index.mjs",
      "./badge": "./dist/components/badge/index.mjs",
      "./code-block": "./dist/components/code-block/index.mjs",
      "./css": "./dist/css.mjs",
      "./package.json": "./package.json"
    }
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest --config vitest.config.ts",
    "test:run": "vitest run --config vitest.config.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@semajsx/core": "workspace:*",
    "@semajsx/signal": "workspace:*",
    "@semajsx/style": "workspace:*"
  },
  "devDependencies": {
    "@semajsx/configs": "workspace:*",
    "@semajsx/dom": "workspace:*",
    "tsdown": "^0.20.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "@semajsx/dom": "workspace:*"
  },
  "peerDependenciesMeta": {
    "@semajsx/dom": {
      "optional": true
    }
  }
}
