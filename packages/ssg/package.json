{
  "name": "@semajsx/ssg",
  "version": "0.2.1",
  "private": true,
  "description": "Static site generation with collections and MDX support for SemaJSX",
  "type": "module",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "exports": {
    ".": "./src/index.ts",
    "./plugins/lucide": "./src/plugins/lucide/index.ts",
    "./plugins/docs-theme": "./src/plugins/docs-theme/index.ts",
    "./plugins/llms": "./src/plugins/llms/index.ts",
    "./package.json": "./package.json"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@mdx-js/mdx": "^3.1.1",
    "@semajsx/core": "workspace:*",
    "@semajsx/dom": "workspace:*",
    "@semajsx/mermaid": "workspace:*",
    "@semajsx/signal": "workspace:*",
    "@semajsx/ssr": "workspace:*",
    "@semajsx/style": "workspace:*",
    "@semajsx/ui": "workspace:*",
    "glob": "^13.0.6",
    "gray-matter": "^4.0.3",
    "lucide": "^1.8.0",
    "remark-gfm": "^4.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@semajsx/configs": "workspace:*",
    "@types/glob": "^9.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  },
  "peerDependencies": {
    "vite": "^7.0.0"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    }
  }
}
