{
  "name": "semajsx-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Monorepo for SemaJSX - A signal-based reactive JSX runtime for building modern web applications",
  "keywords": [
    "framework",
    "jsx",
    "reactive",
    "signal",
    "typescript",
    "ui"
  ],
  "license": "MIT",
  "author": "lidessen",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "type": "module",
  "scripts": {
    "build": "bun run --filter './packages/*' build",
    "dev": "bun run --filter '*' dev",
    "test": "vitest",
    "test:unit": "vitest --config vitest.unit.config.ts",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsgo --build --pretty",
    "typecheck:tsc": "bun run --filter '*' typecheck",
    "typecheck:compare": "bun run typecheck:tsc && bun run typecheck",
    "clean": "bun run --filter '*' clean && rm -rf node_modules",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "oxlint packages",
    "lint:fix": "oxlint --fix packages",
    "prepare": "husky",
    "release": "bun run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/bun": "^1.3.12",
    "@types/node": "^25.6.0",
    "@typescript/native-preview": "7.0.0-dev.20260128.1",
    "@vitest/coverage-v8": "^4.1.4",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
